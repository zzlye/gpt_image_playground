{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/infiniteCanvasSource/*"],
      "next/link": ["src/infiniteCanvasCompat/NextLink.tsx"],
      "next/navigation": ["src/infiniteCanvasCompat/nextNavigation.tsx"]
    },
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  },
  "include": ["src"],
  "exclude": [
    "src/infiniteCanvasSource/app/(admin)/**",
    "src/infiniteCanvasSource/app/api/**",
    "src/infiniteCanvasSource/app/(user)/assets/**",
    "src/infiniteCanvasSource/app/(user)/asset-library/**",
    "src/infiniteCanvasSource/app/(user)/image/**",
    "src/infiniteCanvasSource/app/(user)/login/**",
    "src/infiniteCanvasSource/app/(user)/prompts/**",
    "src/infiniteCanvasSource/app/(user)/video/**",
    "src/infiniteCanvasSource/app/(user)/page.tsx",
    "src/infiniteCanvasSource/app/(user)/layout.tsx",
    "src/infiniteCanvasSource/app/layout.tsx",
    "src/infiniteCanvasSource/app/not-found.tsx"
  ]
}
