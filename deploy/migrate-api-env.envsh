#!/bin/sh

# 兼容旧版本 Docker 环境变量：API_URL 同时作为两个新变量的兜底值。
DOCKER_LEGACY_API_URL_USED=false
if [ -n "$API_URL" ]; then
    DOCKER_LEGACY_API_URL_USED=true
fi

# Docker 默认走文运站；如果用户传旧变量 API_URL，则继续用旧变量兜底。
DEFAULT_API_URL=${DEFAULT_API_URL:-${API_URL:-https://zzlye.xyz:60/v1}}
API_PROXY_URL=${API_PROXY_URL:-${API_URL:-https://zzlye.xyz:60/v1}}

export DEFAULT_API_URL
export API_PROXY_URL
export DOCKER_LEGACY_API_URL_USED
